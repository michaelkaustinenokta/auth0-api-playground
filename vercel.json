{
  "version": 2,
  "builds": [
    {
      "src": "run.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "resources/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/resources/\\.env.*",
      "dest": "/run.js"
    },
    {
      "src": "/(.*\\.(css|js|jpg|jpeg|png|gif|svg|ico|woff|woff2|ttf|eot|otf|webp))",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/api/(.*)",
      "dest": "/run.js"
    },
    {
      "src": "/health",
      "dest": "/run.js"
    },
    {
      "src": "/test.php",
      "dest": "/run.js"
    },
    {
      "src": "/(.*)",
      "dest": "/run.js"
    }
  ]
}
